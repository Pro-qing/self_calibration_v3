<launch>
    <node pkg="self_calibration_v3" type="self_calibration_v3" 
          name="self_calibration_v3" output="screen">
        
        <!-- 坐标系设置 -->
        <param name="lidar_frame" type="string" value="velodyne" />
        <param name="base_frame" type="string" value="base_link" />
        
        <!-- 测试变换参数 -->
        <param name="enable_test_transform" type="bool" value="false" />
        <param name="test_translate_x" type="double" value="0.0" />
        <param name="test_translate_y" type="double" value="0.0" />
        <param name="test_translate_z" type="double" value="0.0" />
        <param name="test_rotate_yaw" type="double" value="0.0" />
        <param name="test_rotate_pitch" type="double" value="0.0" />
        <param name="test_rotate_roll" type="double" value="0.0" />

        <!-- 车间墙面的实际距离（必须根据实际车间测量设置） -->
        <param name="actual_left_distance" type="double" value="0.73" />
        <param name="actual_right_distance" type="double" value="0.645" />
        <param name="actual_front_distance" type="double" value="2.70" />
                
        <!-- 手动测量的雷达高度（必须根据实际车间测量设置）-->
        <param name="manual_lidar_height" type="double" value="1.92" />
        
        <!-- 注意：现在订阅的是 /points_16，16线的激光雷达数据 -->

        <!-- 保存路径 -->
        <param name="save_path" value="/home/getq/laser_self_calibration_workspace/src/self_calibration_v3/param/lidar_calibration.yaml" />
    </node>
</launch>
